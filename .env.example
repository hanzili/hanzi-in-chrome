# ─── Local Development ───────────────────────────────
# Copy this file to .env and fill in values.
# `make dev` loads .env automatically.

# Postgres (local Docker — these match docker-compose.yml defaults)
DATABASE_URL=postgresql://hanzi:hanzi_dev@localhost:5433/hanzi

# Better Auth (required for sign-in)
BETTER_AUTH_SECRET=dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3456

# Google OAuth (required for "Sign in with Google")
# Create at https://console.cloud.google.com/apis/credentials
# Set redirect URI to: http://localhost:3456/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Optional ────────────────────────────────────────

# Stripe (only needed if testing billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_MANAGED_PRICE_ID=

# Vertex AI (only needed for managed LLM routing)
# VERTEX_SA_PATH=path/to/service-account.json
